#!/usr/bin/env bash
#
# gh-reaper - GitHub CLI extension that harvests stale git worktrees
# Version: 1.3.0
# https://github.com/ai-ecoverse/gh-reaper
#
# Seasons don't fear the reaper. Nor do your forgotten worktrees -- until now.
# Scans a curated set of developer directories for linked git worktrees,
# reports how long they've been gathering dust and how much disk they hold,
# then offers to reap the ones you've left behind.

set -euo pipefail

VERSION="1.3.0"
EXTENSION_NAME="gh-reaper"

# Absolute path to this script, so we can re-invoke ourselves as parallel
# inspection workers (see the --__inspect dispatch at the bottom).
SELF_PATH="$(cd "$(dirname "$0")" 2>/dev/null && pwd)/$(basename "$0")"

# Default parallelism = online CPU count (capped), overridable with --jobs.
detect_jobs() {
    local n
    n="$(getconf _NPROCESSORS_ONLN 2>/dev/null \
         || sysctl -n hw.ncpu 2>/dev/null \
         || nproc 2>/dev/null || echo 4)"
    case "$n" in *[!0-9]*|'') n=4 ;; esac
    [ "$n" -gt 16 ] && n=16
    [ "$n" -lt 1 ] && n=1
    echo "$n"
}

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
check_dependencies() {
    local missing=()
    command -v git  >/dev/null 2>&1 || missing+=("git")
    command -v find >/dev/null 2>&1 || missing+=("find")
    command -v du   >/dev/null 2>&1 || missing+=("du")
    command -v stat >/dev/null 2>&1 || missing+=("stat")
    if [ ${#missing[@]} -ne 0 ]; then
        echo "Error: missing required dependencies:" >&2
        printf '  - %s\n' "${missing[@]}" >&2
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Colors (TTY + NO_COLOR aware)
# ---------------------------------------------------------------------------
setup_colors() {
    if [ "${opt_color}" = 1 ] && [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
        C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
        C_RED=$'\033[31m'; C_YELLOW=$'\033[33m'; C_GREEN=$'\033[32m'
        C_CYAN=$'\033[36m'
    else
        C_RESET=''; C_BOLD=''; C_DIM=''
        C_RED=''; C_YELLOW=''; C_GREEN=''; C_CYAN=''
    fi
}

# ---------------------------------------------------------------------------
# Help / version
# ---------------------------------------------------------------------------
show_version() {
    echo "${EXTENSION_NAME} version ${VERSION}"
}

show_help() {
    cat <<EOF
${C_BOLD}gh reaper${C_RESET} - harvest stale git worktrees

  ${C_DIM}"All our times have come / Here but now they're gone"${C_RESET}

USAGE:
  gh reaper [OPTIONS] [PATH...]

DESCRIPTION:
  Scans your developer directories for linked git worktrees and shows when each
  was last touched and how much disk it occupies (oldest first). By default it
  is READ-ONLY -- it lists and changes nothing. Add --reap to actually delete.
  It only walks well-known code roots so it stays fast and never trips macOS
  privacy (TCC) prompts for Desktop, Documents, Downloads, Photos, and friends.

OPTIONS:
  -r, --reap           Delete worktrees (interactive unless --yes). Without this,
                       gh reaper only lists -- it never removes anything.
  -d, --min-age DAYS   Only show worktrees untouched for at least DAYS (default: 0)
  -s, --min-size MB    Only show worktrees at least MB megabytes in size (default: 0)
  -p, --path DIR       Add a scan root (repeatable; also accepted as PATH args)
  -j, --jobs N         Parallel inspection workers (default: CPU count; 1 = serial)
  -a, --all            Scan all of \$HOME (still skips TCC-protected dirs)
  -y, --yes            With --reap, delete without prompting for each worktree
  -f, --force          With --reap, also remove dirty, unpushed, or orphaned worktrees
      --prune          With --reap, run 'git worktree prune' on touched repos afterward
      --json           Emit results as JSON (always read-only)
      --dry-run        List only, change nothing (this is the default; kept for habit)
      --no-color       Disable colored output
  -v, --version        Show version
  -h, --help           Show this help

STATUS FLAGS:
  ${C_GREEN}clean${C_RESET}      No local changes; HEAD exists on a remote -- safe to reap
  ${C_YELLOW}dirty${C_RESET}      Uncommitted or untracked changes present
  ${C_YELLOW}unpushed${C_RESET}   Commits that exist nowhere on a remote
  ${C_RED}orphan${C_RESET}     Main repository is gone; only the checkout remains

EXAMPLES:
  # Survey forgotten worktrees -- read-only, the default
  gh reaper

  # Anything untouched for 30+ days and bigger than 100 MB
  gh reaper --min-age 30 --min-size 100

  # Scan a specific spot, then reap interactively
  gh reaper ~/work/monorepo --reap

  # Reap everything 2+ weeks old, no prompts
  gh reaper --min-age 14 --reap --yes

  # Machine-wide survey (still skips TCC-protected dirs)
  gh reaper --all

More cowbell: https://github.com/ai-ecoverse/gh-reaper
EOF
}

# ---------------------------------------------------------------------------
# Defaults / option state
# ---------------------------------------------------------------------------
opt_min_age_days=0
opt_min_size_mb=0
opt_jobs=""
opt_all=0
opt_reap=0
opt_dry_run=0
opt_yes=0
opt_force=0
opt_prune=0
opt_json=0
opt_color=1
extra_roots=()

parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -r|--reap) opt_reap=1; shift ;;
            -d|--min-age) opt_min_age_days="${2:?--min-age needs a value}"; shift 2 ;;
            -s|--min-size) opt_min_size_mb="${2:?--min-size needs a value}"; shift 2 ;;
            -j|--jobs) opt_jobs="${2:?--jobs needs a value}"; shift 2 ;;
            -p|--path) extra_roots+=("${2:?--path needs a value}"); shift 2 ;;
            -a|--all) opt_all=1; shift ;;
            --dry-run) opt_dry_run=1; shift ;;
            -y|--yes) opt_yes=1; shift ;;
            -f|--force) opt_force=1; shift ;;
            --prune) opt_prune=1; shift ;;
            --json) opt_json=1; shift ;;
            --no-color) opt_color=0; shift ;;
            -v|--version) opt_color=0; setup_colors; show_version; exit 0 ;;
            -h|--help) setup_colors; show_help; exit 0 ;;
            --) shift; while [ $# -gt 0 ]; do extra_roots+=("$1"); shift; done ;;
            -*) echo "Error: unknown option '$1' (try --help)" >&2; exit 1 ;;
            *) extra_roots+=("$1"); shift ;;
        esac
    done

    case "$opt_min_age_days" in *[!0-9]*) echo "Error: --min-age must be a whole number" >&2; exit 1 ;; esac
    case "$opt_min_size_mb"  in *[!0-9]*) echo "Error: --min-size must be a whole number" >&2; exit 1 ;; esac
    if [ -n "$opt_jobs" ]; then
        case "$opt_jobs" in *[!0-9]*) echo "Error: --jobs must be a whole number" >&2; exit 1 ;; esac
        [ "$opt_jobs" -lt 1 ] && { echo "Error: --jobs must be 1 or more" >&2; exit 1; }
    fi

    # Read-only modes win over --reap, so habit and scripts can't delete by surprise.
    if [ "$opt_dry_run" = 1 ] || [ "$opt_json" = 1 ]; then opt_reap=0; fi
}

# ---------------------------------------------------------------------------
# Portable mtime (epoch seconds)
# ---------------------------------------------------------------------------
file_mtime() {
    local f="$1"
    if [ "$STAT_GNU" = 1 ]; then
        stat -c %Y "$f" 2>/dev/null || echo 0
    else
        stat -f %m "$f" 2>/dev/null || echo 0
    fi
}

# ---------------------------------------------------------------------------
# Human-readable helpers
# ---------------------------------------------------------------------------
human_size_kb() {
    local kb="$1"
    if   [ "$kb" -ge 1048576 ]; then awk -v k="$kb" 'BEGIN{printf "%.1fG", k/1048576}'
    elif [ "$kb" -ge 1024 ];    then awk -v k="$kb" 'BEGIN{printf "%.1fM", k/1024}'
    else printf '%dK' "$kb"; fi
}

human_age() {
    local secs="$1" d
    [ "$secs" -lt 0 ] && secs=0
    d=$(( secs / 86400 ))
    if   [ "$d" -ge 365 ]; then printf '%dy'  $(( d / 365 ))
    elif [ "$d" -ge 30 ];  then printf '%dmo' $(( d / 30 ))
    elif [ "$d" -ge 1 ];   then printf '%dd'  "$d"
    else printf '%dh' $(( secs / 3600 )); fi
}

# Replace $HOME prefix with ~ for display
tilde() {
    local p="$1"
    case "$p" in
        "$HOME"/*) printf '~%s' "${p#"$HOME"}" ;;
        "$HOME")   printf '~' ;;
        *)         printf '%s' "$p" ;;
    esac
}

# ---------------------------------------------------------------------------
# Scan roots
# ---------------------------------------------------------------------------
# Directories that trigger macOS TCC permission dialogs or are pure noise.
# Always pruned, even under --all.
TCC_DENY=(
    "$HOME/Library" "$HOME/Desktop" "$HOME/Documents" "$HOME/Downloads"
    "$HOME/Pictures" "$HOME/Movies" "$HOME/Music" "$HOME/Public"
    "$HOME/.Trash" "$HOME/Applications"
    "/Volumes" "/System" "/private" "/Network" "/cores" "/Library"
)

resolve_roots() {
    local candidates=()
    local r
    # Explicit paths win and skip the curated/TCC logic.
    if [ ${#extra_roots[@]} -gt 0 ]; then
        for r in "${extra_roots[@]}"; do candidates+=("$r"); done
    elif [ "$opt_all" = 1 ]; then
        candidates+=("$HOME")
    else
        # Curated, fast, TCC-safe defaults -- only the ones that exist.
        local maybe=(
            "$PWD"
            "$HOME/Developer" "$HOME/Projects" "$HOME/projects"
            "$HOME/Code" "$HOME/code" "$HOME/src" "$HOME/Source"
            "$HOME/dev" "$HOME/Dev" "$HOME/git" "$HOME/repos" "$HOME/Repositories"
            "$HOME/work" "$HOME/workspace" "$HOME/Workspace"
            "$HOME/conductor" "$HOME/.conductor"
            "$HOME/intent/workspaces"
            "$HOME/.codex/worktrees"
            "$HOME/worktrees" "$HOME/.worktrees"
            "$HOME/go/src"
        )
        for r in "${maybe[@]}"; do [ -d "$r" ] && candidates+=("$r"); done
    fi

    # Normalize, dedupe, drop nonexistent.
    local seen=" "
    for r in "${candidates[@]}"; do
        [ -d "$r" ] || continue
        r="$(cd "$r" 2>/dev/null && pwd)" || continue
        case "$seen" in *" $r "*) continue ;; esac
        seen="$seen$r "
        printf '%s\n' "$r"
    done
}

# Emit '.git' worktree-marker files under a root, pruning heavy / protected dirs.
find_git_markers() {
    local root="$1"
    local prune=()
    local d
    for d in "${TCC_DENY[@]}"; do prune+=( -path "$d" -o ); done
    find "$root" \
        \( "${prune[@]}" \
           -type d \( -name node_modules -o -name .git -o -name .Trash \
                      -o -name Library -o -name .cache -o -name Caches \
                      -o -name .npm -o -name .pnpm-store -o -name .yarn \
                      -o -name .venv -o -name venv -o -name .tox \
                      -o -name .gradle -o -name .terraform -o -name .next \
                      -o -name DerivedData -o -name Pods -o -name '*.noindex' \
                      -o -name .workspace \) \
        \) -prune -o \
        -type f -name .git -print 2>/dev/null
}

# ---------------------------------------------------------------------------
# Inspect one worktree marker; append a record to RECORDS on success.
# Record fields (tab-separated): touched  kb  branch  status  path  main
# ---------------------------------------------------------------------------
inspect_marker() {
    local gitfile="$1" wt line gitdir
    wt="$(dirname "$gitfile")"

    IFS= read -r line < "$gitfile" 2>/dev/null || return 0
    case "$line" in gitdir:*) gitdir="${line#gitdir: }" ;; *) return 0 ;; esac
    # Only worktrees -- not submodules ('.../modules/...').
    case "$gitdir" in */worktrees/*) ;; *) return 0 ;; esac
    # Resolve a relative gitdir against the worktree.
    case "$gitdir" in /*) ;; *) gitdir="$wt/$gitdir" ;; esac

    # "Last touched" from signals git's *read* commands never rewrite:
    # the working-dir mtime, the reflog (logs/HEAD), and the last commit date.
    # (The index is deliberately ignored -- `git status` rewrites it, which
    # would reset a worktree's apparent age every time we inspect it.)
    local kb touched dir_m logs_m branch status main
    # No pipe into an early-exit filter here: on a big tree `du` is still
    # writing when the reader quits, and SIGPIPE + pipefail would kill us.
    kb="$(du -sk "$wt" 2>/dev/null)" || kb=""
    kb="${kb%%[[:space:]]*}"; : "${kb:=0}"
    dir_m="$(file_mtime "$wt")"
    logs_m="$(file_mtime "$gitdir/logs/HEAD")"
    touched="$dir_m"
    [ "$logs_m" -gt "$touched" ] && touched="$logs_m"

    if git -C "$wt" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        local commit_ct ahead up
        commit_ct="$(git -C "$wt" log -1 --format=%ct 2>/dev/null || echo 0)"
        [ "${commit_ct:-0}" -gt "$touched" ] && touched="$commit_ct"

        branch="$(git -C "$wt" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
        [ -z "$branch" ] && branch="detached@$(git -C "$wt" rev-parse --short HEAD 2>/dev/null || echo '?')"

        status="clean"
        if [ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]; then
            status="dirty"
        fi
        # Unpushed = commits that live nowhere on a remote.
        if up="$(git -C "$wt" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)"; then
            ahead="$(git -C "$wt" rev-list --count "${up}..HEAD" 2>/dev/null || echo 0)"
            if [ "${ahead:-0}" -gt 0 ]; then
                [ "$status" = clean ] && status="unpushed" || status="$status unpushed"
            fi
        elif [ -z "$(git -C "$wt" branch -r --contains HEAD 2>/dev/null)" ]; then
            [ "$status" = clean ] && status="unpushed" || status="$status unpushed"
        fi

        # First porcelain line is "worktree <main-path>"; parse without a pipe.
        main="$(git -C "$wt" worktree list --porcelain 2>/dev/null)" || main=""
        main="${main%%$'\n'*}"; main="${main#worktree }"
        [ -z "$main" ] && main="$wt"
    else
        # Git can't operate -> the main repo is gone.
        status="orphan"
        branch="?"
        if [ -r "$gitdir/HEAD" ]; then
            IFS= read -r line < "$gitdir/HEAD" 2>/dev/null || line=""
            branch="${line#ref: refs/heads/}"
        fi
        main=""
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$touched" "$kb" "$branch" "$status" "$wt" "$main"
}

# ---------------------------------------------------------------------------
# Reaping
# ---------------------------------------------------------------------------
is_risky() { case "$1" in *dirty*|*unpushed*|*orphan*) return 0 ;; *) return 1 ;; esac; }

reap_one() {
    local wt="$1" main="$2" status="$3"
    if [ "$status" = "orphan" ] || [ -z "$main" ]; then
        rm -rf "$wt"
        return $?
    fi
    local args=(worktree remove)
    case "$status" in *dirty*|*unpushed*) args+=(--force) ;; esac
    args+=("$wt")
    git -C "$main" "${args[@]}" 2>&1
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    parse_args "$@"
    setup_colors

    if stat --version >/dev/null 2>&1; then STAT_GNU=1; else STAT_GNU=0; fi

    local NOW; NOW="$(date +%s)"
    local min_age_secs=$(( opt_min_age_days * 86400 ))
    local min_kb=$(( opt_min_size_mb * 1024 ))

    # ---- discover ----
    local roots=(); local root
    while IFS= read -r root; do roots+=("$root"); done < <(resolve_roots)
    if [ ${#roots[@]} -eq 0 ]; then
        echo "No scannable directories found. Pass a PATH or use --all." >&2
        exit 1
    fi

    local jobs="${opt_jobs:-$(detect_jobs)}"

    # ---- collect unique worktree markers across all roots ----
    local markers=() marker seen_markers=" "
    for root in "${roots[@]}"; do
        while IFS= read -r marker; do
            [ -n "$marker" ] || continue
            case "$seen_markers" in *" $marker "*) continue ;; esac
            seen_markers="$seen_markers$marker "
            markers+=("$marker")
        done < <(find_git_markers "$root")
    done

    if [ "$opt_json" = 0 ]; then
        printf '%s%s: inspecting %d worktree(s) across %d root(s), %d job(s)...%s\n' \
            "$C_DIM" "$EXTENSION_NAME" "${#markers[@]}" "${#roots[@]}" "$jobs" "$C_RESET" >&2
    fi

    # ---- inspect markers in parallel ----
    # Each worker (a re-invocation of this script) appends finished records to
    # its own per-PID temp file, so output never interleaves and we don't rely
    # on pipe write-atomicity. The slow part (du + git per worktree) now runs
    # `jobs`-wide instead of serially.
    RECORDS=()
    if [ ${#markers[@]} -gt 0 ]; then
        local outdir rec_line
        outdir="$(mktemp -d)"
        printf '%s\0' "${markers[@]}" \
            | REAPER_OUT_DIR="$outdir" xargs -0 -P "$jobs" -n 16 "$SELF_PATH" --__inspect 2>/dev/null || true
        while IFS= read -r rec_line; do
            [ -n "$rec_line" ] && RECORDS+=("$rec_line")
        done < <(cat "$outdir"/*.tsv 2>/dev/null)
        rm -rf "$outdir"
    fi

    # ---- filter + sort (oldest first) ----
    local filtered=()
    local rec touched kb branch status path main age
    for rec in "${RECORDS[@]:-}"; do
        [ -n "$rec" ] || continue
        IFS=$'\t' read -r touched kb branch status path main <<<"$rec"
        age=$(( NOW - touched ))
        [ "$age" -lt "$min_age_secs" ] && continue
        [ "$kb" -lt "$min_kb" ] && continue
        filtered+=("$rec")
    done

    if [ ${#filtered[@]} -eq 0 ]; then
        if [ "$opt_json" = 1 ]; then echo "[]"; else
            printf '%sNothing to reap.%s The fields are clean.\n' "$C_GREEN" "$C_RESET"
        fi
        exit 0
    fi

    # Sort ascending by touched epoch (first field).
    local sorted=()
    while IFS= read -r rec; do sorted+=("$rec"); done < <(printf '%s\n' "${filtered[@]}" | sort -t$'\t' -k1,1n)

    # ---- JSON output ----
    if [ "$opt_json" = 1 ]; then
        printf '%s\n' "${sorted[@]}" | jq -R -s --argjson now "$NOW" '
            split("\n") | map(select(length>0)) | map(split("\t")) |
            map({
              path: .[4], branch: .[2], status: .[3],
              sizeKb: (.[1]|tonumber),
              touched: (.[0]|tonumber),
              ageDays: (($now - (.[0]|tonumber)) / 86400 | floor),
              mainWorktree: .[5]
            })'
        exit 0
    fi

    # ---- table ----
    local total_kb=0
    printf '\n%s%-6s %8s  %-14s %-22s %s%s\n' "$C_BOLD" "AGE" "SIZE" "STATUS" "BRANCH" "PATH" "$C_RESET"
    for rec in "${sorted[@]}"; do
        IFS=$'\t' read -r touched kb branch status path main <<<"$rec"
        age=$(( NOW - touched ))
        total_kb=$(( total_kb + kb ))
        local color="$C_DIM"
        case "$status" in
            *orphan*)            color="$C_RED" ;;
            *dirty*|*unpushed*)  color="$C_YELLOW" ;;
            clean)               color="$C_GREEN" ;;
        esac
        local br="$branch"; [ ${#br} -gt 22 ] && br="${br:0:21}…"
        printf '%s%-6s %8s  %-14s %-22s %s%s\n' \
            "$color" "$(human_age "$age")" "$(human_size_kb "$kb")" \
            "$status" "$br" "$(tilde "$path")" "$C_RESET"
    done
    printf '%s%d worktree(s), %s total%s\n\n' \
        "$C_DIM" "${#sorted[@]}" "$(human_size_kb "$total_kb")" "$C_RESET"

    # Read-only unless explicitly asked to reap.
    if [ "$opt_reap" != 1 ]; then
        if [ "$opt_yes" = 1 ] || [ "$opt_force" = 1 ] || [ "$opt_prune" = 1 ]; then
            printf '%snote: --yes/--force/--prune do nothing without --reap; nothing was deleted.%s\n' \
                "$C_DIM" "$C_RESET" >&2
        fi
        printf '%sRead-only listing -- nothing deleted. Add %s--reap%s%s to delete (interactive), or %s--reap --yes%s%s to skip prompts.%s\n' \
            "$C_DIM" "$C_BOLD$C_CYAN" "$C_RESET" "$C_DIM" "$C_BOLD$C_CYAN" "$C_RESET" "$C_DIM" "$C_RESET"
        exit 0
    fi

    # ---- reap ----
    local reap_all="$opt_yes" reaped=0 freed_kb=0 ans out
    local touched_mains=()
    for rec in "${sorted[@]}"; do
        IFS=$'\t' read -r touched kb branch status path main <<<"$rec"

        if is_risky "$status" && [ "$opt_force" != 1 ]; then
            printf '%s skip%s %s %s(%s -- needs --force)%s\n' \
                "$C_YELLOW" "$C_RESET" "$(tilde "$path")" "$C_DIM" "$status" "$C_RESET"
            continue
        fi

        if [ "$reap_all" != 1 ]; then
            printf 'Reap %s%s%s [%s, %s, %s]? [y/N/a/q] ' \
                "$C_CYAN" "$(tilde "$path")" "$C_RESET" \
                "$(human_age $(( NOW - touched )))" "$(human_size_kb "$kb")" "$status"
            read -r ans </dev/tty || ans="q"
            case "$ans" in
                y|Y) ;;
                a|A) reap_all=1 ;;
                q|Q) echo "Stopped."; break ;;
                *)   continue ;;
            esac
        fi

        if out="$(reap_one "$path" "$main" "$status")"; then
            printf '%s reaped%s %s\n' "$C_GREEN" "$C_RESET" "$(tilde "$path")"
            reaped=$(( reaped + 1 ))
            freed_kb=$(( freed_kb + kb ))
            [ -n "$main" ] && touched_mains+=("$main")
        else
            printf '%s failed%s %s\n  %s%s%s\n' \
                "$C_RED" "$C_RESET" "$(tilde "$path")" "$C_DIM" "$out" "$C_RESET"
        fi
    done

    if [ "$opt_prune" = 1 ] && [ ${#touched_mains[@]} -gt 0 ]; then
        local m seen=" "
        for m in "${touched_mains[@]}"; do
            case "$seen" in *" $m "*) continue ;; esac
            seen="$seen$m "
            git -C "$m" worktree prune 2>/dev/null || true
        done
    fi

    printf '\n%sReaped %d worktree(s), reclaimed %s.%s\n' \
        "$C_BOLD" "$reaped" "$(human_size_kb "$freed_kb")" "$C_RESET"
}

# Internal parallel-inspection worker (not a public interface). main() re-invokes
# this script via xargs as `gh-reaper --__inspect <marker>...`; each call writes
# one TSV record per valid worktree to $REAPER_OUT_DIR/$$.tsv (or stdout).
if [ "${1:-}" = "--__inspect" ]; then
    if stat --version >/dev/null 2>&1; then STAT_GNU=1; else STAT_GNU=0; fi
    shift
    for __m in "$@"; do
        __rec="$(inspect_marker "$__m" 2>/dev/null)" || __rec=""
        [ -n "$__rec" ] || continue
        if [ -n "${REAPER_OUT_DIR:-}" ]; then
            printf '%s\n' "$__rec" >> "$REAPER_OUT_DIR/$$.tsv"
        else
            printf '%s\n' "$__rec"
        fi
    done
    exit 0
fi

check_dependencies
main "$@"
